OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_LLM_MODEL=qwen2.5:3b
OLLAMA_EMBED_MODEL=nomic-embed-text
QDRANT_PATH=storage/qdrant
QDRANT_COLLECTION=kevin_personal_rag
DATA_DIR=data/raw
VERSIONS_DIR=data/versions
MANIFEST_PATH=storage/manifests/documents.json
CHUNK_SIZE=600
CHUNK_OVERLAP=80
SIMILARITY_TOP_K=4
REQUEST_TIMEOUT=180
MIN_FREE_DISK_GB=3
DEBUG_SOURCES=false

# Fase 2 — autenticación (PostgreSQL)
DATABASE_URL=postgresql+psycopg://USUARIO:CONTRASEÑA@HOST:PUERTO/rag_auth
AUTH_ADMIN_USERNAME=admin
# Solo se usa en el PRIMER init-db si el admin no existe.
# Después cambie la clave con: python -m auth.cli change-password
# y puede quitar o vaciar esta variable del .env real.
AUTH_ADMIN_PASSWORD=CambiarAdmin123!
AUTH_SESSION_HOURS=8
AUTH_MAX_FAILED_ATTEMPTS=5
AUTH_LOCK_MINUTES=15
AUTH_SESSION_FILE=storage/auth_session.json
AUTH_REQUIRED=true
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
API_HOST=127.0.0.1
API_PORT=8000
